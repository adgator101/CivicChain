.git
.gitignore
.vscode
.agent
.kiro

# Docker
Dockerfile
.dockerignore
docker-compose.yml

# Misc
README.md
*.md
npm-debug.log*
.DS_Store

# Local runtime uploads (legacy local storage; uploads now go to Cloudinary)
public/uploads/*
!public/uploads/.gitkeep
