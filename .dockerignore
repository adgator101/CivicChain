# Dependencies & build output (reinstalled / regenerated inside the image)
node_modules
.next
out
build
coverage

# Generated Prisma client (regenerated via `prisma generate` during build)
src/generated

# Env & secrets — passed at runtime via --env-file / compose, never baked in
.env
.env.*

